# Server Configuration
PORT=4000
ENV=development
APP_NAME="Go Fiber Boilerplate API"

# Database Configuration
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=fiber_boilerplate
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# Redis / Cache (leave REDIS_HOST empty to disable: cache no-op + in-memory rate limiter)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
CACHE_ENABLED=true
CACHE_TTL=5m

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:4000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# Logging
LOG_LEVEL=info
LOG_HTTP_BODY=true
LOG_BODY_MAX_BYTES=8192
LOG_RETENTION_DAYS=14
LOG_HEALTH_SAMPLE_N=20
LOG_QUIET=true

# Sentry (optional placeholder; empty disables integration)
SENTRY_DSN=
SENTRY_LOG_LEVEL=info
SENTRY_TRACES_SAMPLE_RATE=0

# Server Timeouts
READ_TIMEOUT=10s
WRITE_TIMEOUT=10s
IDLE_TIMEOUT=60s

# Email Configuration (optional; empty disables email-backed flows)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Go Fiber Boilerplate
SMTP_FROM_EMAIL=
